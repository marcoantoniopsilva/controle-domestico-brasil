{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://eepkixxqvelppxzfwoin.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "plenna-mcp",
      "version": "0.1.0",
      "title": "Plenna Finanças"
    },
    "tools": [
      {
        "name": "list_transactions",
        "title": "Listar lançamentos",
        "description": "Lista os lançamentos financeiros (despesas, receitas, investimentos) do usuário autenticado. Aceita filtros opcionais por intervalo de datas, tipo e categoria.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "data_inicio": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "Data inicial no formato YYYY-MM-DD."
            },
            "data_fim": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "Data final no formato YYYY-MM-DD."
            },
            "tipo": {
              "type": "string",
              "enum": [
                "despesa",
                "receita",
                "investimento"
              ]
            },
            "categoria": {
              "type": "string",
              "description": "Filtrar por nome exato de categoria."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500,
              "description": "Máximo de registros (padrão 100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "create_transaction",
        "title": "Criar lançamento",
        "description": "Cria um novo lançamento financeiro para o usuário autenticado. Despesas devem ter valor negativo; receitas e investimentos positivos.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "data": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "Data do lançamento no formato YYYY-MM-DD."
            },
            "categoria": {
              "type": "string",
              "minLength": 1,
              "description": "Nome da categoria (deve existir em list_categories)."
            },
            "valor": {
              "type": "number",
              "description": "Valor em reais. Despesas devem ser negativas."
            },
            "tipo": {
              "type": "string",
              "enum": [
                "despesa",
                "receita",
                "investimento"
              ]
            },
            "descricao": {
              "type": "string"
            },
            "parcelas": {
              "type": "integer",
              "minimum": 1,
              "maximum": 60,
              "description": "Número de parcelas (padrão 1)."
            },
            "quem_gastou": {
              "type": "string"
            },
            "cartao_id": {
              "type": "string",
              "format": "uuid"
            },
            "conta_id": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "data",
            "categoria",
            "valor",
            "tipo"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_categories",
        "title": "Listar categorias",
        "description": "Lista as categorias ativas do usuário com seus orçamentos.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "tipo": {
              "type": "string",
              "enum": [
                "despesa",
                "receita",
                "investimento"
              ]
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_accounts",
        "title": "Listar contas bancárias",
        "description": "Lista as contas bancárias ativas do usuário.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_credit_cards",
        "title": "Listar cartões de crédito",
        "description": "Lista os cartões de crédito ativos do usuário.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_goals",
        "title": "Listar metas & reservas",
        "description": "Lista as metas financeiras (reservas, viagens, compras) do usuário com o total aportado em cada uma.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "cycle_summary",
        "title": "Resumo do ciclo",
        "description": "Retorna o resumo financeiro do ciclo atual (ou de uma data de referência): total de receitas, despesas, investimentos e saldo.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "data_referencia": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "Data dentro do ciclo desejado. Padrão: hoje."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
